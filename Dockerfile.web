# Web-managed multi-account miner (web UI + backend + miner engine).
# Build: docker build -f Dockerfile.web -t twitch-miner-manager .
#
# ---- Stage 1: build the React frontend ----
FROM node:22-alpine AS frontend
WORKDIR /fe
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY frontend/ ./
RUN npm run build

# ---- Stage 2: Python runtime (backend + miner engine) ----
FROM python:3.11-slim
WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DATA_DIR=/data

# tini = proper PID 1 (reaps miner subprocesses, forwards signals)
RUN apt-get update \
    && apt-get install -y --no-install-recommends tini \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./requirements.txt
COPY backend/requirements.txt ./backend-requirements.txt
RUN pip install --no-cache-dir -r requirements.txt -r backend-requirements.txt

# Application code
COPY TwitchChannelPointsMiner ./TwitchChannelPointsMiner
COPY backend ./backend
COPY miner_runner.py run.py ./

# Built frontend from stage 1
COPY --from=frontend /fe/dist ./frontend/dist

VOLUME ["/data"]
EXPOSE 8000

ENTRYPOINT ["tini", "--"]
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
