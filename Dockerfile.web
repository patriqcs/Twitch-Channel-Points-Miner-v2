# Web-managed multi-account miner (web UI + backend + miner engine).
# Build: docker build -f Dockerfile.web -t twitch-miner-manager .
#
# ---- Stage 1: build the React frontend ----
FROM node:22-alpine AS frontend
WORKDIR /fe
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY frontend/ ./
RUN npm run build

# ---- Stage 2: Python runtime (backend + miner engine) ----
FROM python:3.11-slim
WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DATA_DIR=/data

# tini = proper PID 1 (reaps miner subprocesses, forwards signals).
# wireguard-tools/iproute2/iptables = optional built-in Mullvad tunnel (wg-quick);
# iputils-ping = tunnel sanity check in the entrypoint.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        tini wireguard-tools iproute2 iptables iputils-ping \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./requirements.txt
COPY backend/requirements.txt ./backend-requirements.txt
RUN pip install --no-cache-dir -r requirements.txt -r backend-requirements.txt

# Application code
COPY TwitchChannelPointsMiner ./TwitchChannelPointsMiner
COPY backend ./backend
COPY miner_runner.py run.py ./
COPY docker-entrypoint-web.sh /usr/local/bin/docker-entrypoint-web.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-web.sh

# Built frontend from stage 1
COPY --from=frontend /fe/dist ./frontend/dist

VOLUME ["/data"]
# Default port; override at runtime with -e WEB_PORT=<port>.
ENV WEB_PORT=8000
EXPOSE 8000

# Entrypoint optionally brings up the Mullvad WireGuard tunnel, then execs
# uvicorn (kept as tini's child for proper PID reaping/signals).
ENTRYPOINT ["tini", "--"]
CMD ["/usr/local/bin/docker-entrypoint-web.sh"]
