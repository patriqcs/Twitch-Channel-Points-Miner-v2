# Keep the build context small and avoid clobbering the in-image `npm ci`
# with a host node_modules.
.git
.gitignore

# Frontend: build happens inside the image (stage 1)
frontend/node_modules
frontend/dist

# Python caches / virtualenvs
**/__pycache__
**/*.pyc
.venv
venv

# Runtime data (cookies, logs, db, secret key)
data
logs
cookies
*.log
*.db

# Local dev / editor
.vscode
.idea
.DS_Store
